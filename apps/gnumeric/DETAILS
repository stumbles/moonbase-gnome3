          MODULE=gnumeric
         VERSION=1.12.61
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$GNOME_URL/sources/$MODULE/${VERSION%.*}
      SOURCE_VFY=sha256:2ac135d856572713c1a408b76b50a59f2a9769ed21f1213446b5af255df20a12
        WEB_SITE=http://www.gnumeric.org
         ENTERED=20021224
         UPDATED=20260516
           SHORT="The GNOME spreadsheet application"

cat << EOF
Gnumeric is a powerful spreadsheet application that interoperates well with
other spreadsheets. It comes with plugins that enable it to deal with
commonly-used spreadsheet file formats. Gnumeric is intended to be a drop-in
replacement for commercial spreadsheets.
Gnumeric will import your existing Excel, 1-2-3, Applix, Sylk, XBase and Oleo
files. Gnumeric can export to LaTeX 2e (.tex), TROFF (.me) and HTML as well.
EOF
